---
import { siteConfig } from '../../config/site';
---

<section id="hero" class="hero reveal-section">
  <div class="hero-image-wrap">
    <div class="hero-image-glow"></div>
    <img
      src="/images/profile.jpg"
      alt="Pratik Bhattarai"
      class="hero-image neon-glow"
      loading="eager"
    />
  </div>

  <h1 class="hero-title">{siteConfig.name}</h1>
  <h2 class="hero-subtitle">{siteConfig.title}</h2>

  <p class="hero-description">
    Orchestrating bare-metal hardware into mission-critical cloud infrastructure. Specialized in
    high-availability, self-hosted environments and zero-trust security.
  </p>

  <div class="hero-actions">
    <a
      class="hero-button hero-button-primary btn-glow-hover"
      href={siteConfig.githubUrl}
      target="_blank"
      rel="noreferrer"
    >
      <span>View GitHub</span>
      <img src="/icons/github.svg" alt="GitHub" class="hero-icon" loading="lazy" />
    </a>

    <a
      class="hero-button hero-button-outline btn-glow-hover"
      href={siteConfig.linkedinUrl}
      target="_blank"
      rel="noreferrer"
    >
      LinkedIn
    </a>

    <a
      class="hero-button hero-button-muted btn-glow-hover"
      href={siteConfig.cvUrl}
    >
      Download CV
    </a>
  </div>
</section>
