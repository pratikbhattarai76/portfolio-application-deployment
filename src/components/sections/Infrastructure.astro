<section id="infrastructure" class="infrastructure-section">
  <div class="infrastructure-card glass-effect reveal-section">
    <header class="infrastructure-header">
      <div class="infrastructure-dots">
        <span class="infrastructure-dot infrastructure-dot-red"></span>
        <span class="infrastructure-dot infrastructure-dot-yellow"></span>
        <span class="infrastructure-dot infrastructure-dot-green"></span>
      </div>
      <span class="infrastructure-title">@root:pratik</span>
    </header>

    <div class="infrastructure-body">
      <div class="infrastructure-status reveal-item" style="--reveal-order: 1;">
        <div class="infrastructure-status-icon"></div>
        <div>
          <a class="infrastructure-status-label-link"
             href="https://status.pratik-labs.xyz"
             target="_blank"
             rel="noopener noreferrer">
            <span class="infrastructure-status-label">ONLINE</span>
          </a>
          <p class="infrastructure-status-subtitle">Node Connected</p>
        </div>
      </div>

      <div class="infrastructure-specs reveal-item" style="--reveal-order: 2;">
        <div class="infrastructure-spec">
          <div class="infrastructure-spec-icon">CPU</div>
          <div>
            <p class="infrastructure-spec-main">Intel Core i7-4770</p>
            <p class="infrastructure-spec-sub">8 Threads @ 3.40GHz</p>
          </div>
        </div>

        <div class="infrastructure-spec">
          <div class="infrastructure-spec-icon">RAM</div>
          <div>
            <p class="infrastructure-spec-main">16GB DDR3</p>
            <p class="infrastructure-spec-sub">1333 MHZ</p>
          </div>
        </div>

        <div class="infrastructure-spec">
          <div class="infrastructure-spec-icon">DISK</div>
          <div>
            <p class="infrastructure-spec-main">120GB SSD + 1TB HDD</p>
            <p class="infrastructure-spec-sub">Tiered Storage Architecture</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
