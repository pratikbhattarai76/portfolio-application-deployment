<section id="deployments" class="deployments-section">
  <header class="deployments-header">
    <h2 class="deployments-title">Microservice Command Center</h2>
    <p class="deployments-subtitle">Accessing Distributed Infrastructure</p>
  </header>

  <div class="deployments-grid">
    <article class="deployment-card">
      <header class="deployment-card-header">
        <span class="deployment-card-icon">NC</span>
        <span class="deployment-card-badge deployment-card-badge-green">PUBLIC BETA</span>
      </header>
      <h3 class="deployment-card-title">Nextcloud</h3>
      <p class="deployment-card-text">
        High-concurrency file storage and collaboration, optimized for low-latency web access.
      </p>
      <button class="deployment-card-button">
        Initialize Connection
      </button>
    </article>

    <article class="deployment-card">
      <header class="deployment-card-header">
        <span class="deployment-card-icon">VW</span>
        <span class="deployment-card-badge deployment-card-badge-red">RESTRICTED</span>
      </header>
      <h3 class="deployment-card-title">Vaultwarden</h3>
      <p class="deployment-card-text">
        Hardened secrets management behind a zero-trust tunnel with mTLS authentication.
      </p>
      <button class="deployment-card-button deployment-card-button-disabled" disabled>
        Access Forbidden
      </button>
    </article>

    <article class="deployment-card">
      <header class="deployment-card-header">
        <span class="deployment-card-icon">GF</span>
        <span class="deployment-card-badge deployment-card-badge-cyan">REALTIME</span>
      </header>
      <h3 class="deployment-card-title">Grafana</h3>
      <p class="deployment-card-text">
        Full-stack telemetry dashboards aggregating metrics from Prometheus and Node Exporters.
      </p>
      <button class="deployment-card-button">
        Stream Metrics
      </button>
    </article>
  </div>
</section>

